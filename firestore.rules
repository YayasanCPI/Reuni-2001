rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /attendees/{attendeeId} {
      // Allow anyone to read the attendee list (needed for AttendeeCounter and AttendeeList)
      allow read: if true;
      
      // Allow anyone to create an RSVP, but validate basic structure if needed
      // (For this RSVP form, we allow unauthenticated creates)
      allow create: if true;
      
      // Do not allow unauthenticated updates or deletes
      allow update, delete: if false;
    }
    
    match /messages/{messageId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
